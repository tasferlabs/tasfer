{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "jsx": "react-jsx",

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "*": ["./*"],
      "@cypherkit/editor": ["../../packages/editor/src/index.ts"],
      "@cypherkit/editor/*": ["../../packages/editor/src/*"],
      "@cypherkit/tex": ["../../packages/tex/src/index.ts"],
      "@cypherkit/tex/*": ["../../packages/tex/src/*"],
      "@cypherkit/react": ["../../packages/react/src/index.ts"],
      "@cypherkit/react/*": ["../../packages/react/src/*"],
      "@cypherkit/provider-core": ["../../packages/provider-core/src/index.ts"],
      "@cypherkit/provider-core/*": ["../../packages/provider-core/src/*"],
      "@/*": ["./src/*"],
      "@shared/*": ["../../shared/*"],
      "react": ["./node_modules/@types/react"],
      "react/*": ["./node_modules/@types/react/*"],
      "react-dom": ["./node_modules/@types/react-dom"],
      "react-dom/*": ["./node_modules/@types/react-dom/*"]
    }
  },
  "include": ["src"]
}
