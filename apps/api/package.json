{
  "name": "api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "env-cmd -f .env.development bun --watch ./src/index.ts",
    "build": "tsc --noEmit",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.0.6",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.1",
    "env-cmd": "^11.0.0",
    "express": "^5.2.1",
    "ioredis": "^5.9.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "protobufjs": "^8.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.9.3"
  }
}
