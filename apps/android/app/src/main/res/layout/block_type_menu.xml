<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="300dp"
    android:background="@color/card"
    android:orientation="vertical">

    <!-- Header -->
    <TextView
        android:id="@+id/blockMenuHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Turn into"
        android:textSize="16sp"
        android:textColor="@color/foreground"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:fontFamily="sans-serif-medium" />

    <!-- Scrollable Grid -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="5"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false"
            android:useDefaultMargins="false">

            <!-- Text Button -->
            <Button
                android:id="@+id/paragraphButton"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_background"
                android:drawableStart="@drawable/ic_text"
                android:drawablePadding="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/paragraph"
                android:textAlignment="viewStart"
                android:textAllCaps="false"
                android:textColor="@color/foreground"
                android:textSize="15sp" />

            <!-- Heading 1 Button -->
            <Button
                android:id="@+id/heading1Button"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_background"
                android:drawableStart="@drawable/ic_heading1"
                android:drawablePadding="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/heading_1"
                android:textAlignment="viewStart"
                android:textAllCaps="false"
                android:textColor="@color/foreground"
                android:textSize="15sp" />

            <!-- Heading 2 Button -->
            <Button
                android:id="@+id/heading2Button"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_background"
                android:drawableStart="@drawable/ic_heading2"
                android:drawablePadding="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/heading_2"
                android:textAlignment="viewStart"
                android:textAllCaps="false"
                android:textColor="@color/foreground"
                android:textSize="15sp" />

            <!-- Heading 3 Button -->
            <Button
                android:id="@+id/heading3Button"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_background"
                android:drawableStart="@drawable/ic_heading3"
                android:drawablePadding="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/heading_3"
                android:textAlignment="viewStart"
                android:textAllCaps="false"
                android:textColor="@color/foreground"
                android:textSize="15sp" />

            <!-- Numbered List Button -->
            <Button
                android:id="@+id/numberedListButton"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_background"
                android:drawableStart="@drawable/ic_list_ordered"
                android:drawablePadding="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/numbered_list"
                android:textAlignment="viewStart"
                android:textAllCaps="false"
                android:textColor="@color/foreground"
                android:textSize="15sp" />

            <!-- Task List Button -->
            <Button
                android:id="@+id/taskListButton"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_background"
                android:drawableStart="@drawable/ic_list_todo"
                android:drawablePadding="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/task_list"
                android:textAlignment="viewStart"
                android:textAllCaps="false"
                android:textColor="@color/foreground"
                android:textSize="15sp" />

            <!-- Bulleted List Button -->
            <Button
                android:id="@+id/bulletedListButton"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_background"
                android:drawableStart="@drawable/ic_list"
                android:drawablePadding="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/bulleted_list"
                android:textAlignment="viewStart"
                android:textAllCaps="false"
                android:textColor="@color/foreground"
                android:textSize="15sp" />

            <!-- Image Button -->
            <Button
                android:id="@+id/imageButton"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_background"
                android:drawableStart="@drawable/ic_image"
                android:drawablePadding="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/image"
                android:textAlignment="viewStart"
                android:textAllCaps="false"
                android:textColor="@color/foreground"
                android:textSize="15sp" />

            <!-- Divider Button -->
            <Button
                android:id="@+id/dividerButton"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/button_background"
                android:drawableStart="@drawable/ic_line"
                android:drawablePadding="12dp"
                android:gravity="start|center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/divider"
                android:textAlignment="viewStart"
                android:textAllCaps="false"
                android:textColor="@color/foreground"
                android:textSize="15sp" />

        </GridLayout>
    </ScrollView>

</LinearLayout>

