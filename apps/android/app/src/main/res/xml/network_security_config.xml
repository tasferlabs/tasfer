<?xml version="1.0" encoding="utf-8"?>
<!-- Release config: TLS only, system CAs only.
     Debug builds override this via app/src/debug/res/xml/. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
