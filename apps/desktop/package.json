{
  "name": "tasfer-desktop",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "description": "Tasfer desktop application",
  "homepage": "https://github.com/tasferlabs/tasfer",
  "author": {
    "name": "Hamza Khuswan",
    "email": "hi@hamza.se"
  },
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "gen:strings": "node ../web/scripts/gen-desktop-strings.mjs",
    "build": "npm run gen:strings && electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "package:dir": "electron-builder --dir",
    "package:linux": "electron-builder --linux",
    "package:linux:appimage": "electron-builder --linux AppImage",
    "package:linux:deb": "electron-builder --linux deb",
    "package:linux:pacman": "electron-builder --linux pacman",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2"
  }
}
