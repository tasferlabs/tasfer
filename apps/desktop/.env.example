# Copy to `.env` and adjust for your machine. `.env` is gitignored.
#
# Dev-server URL the desktop app loads in development (`npm run dev`).
# Only `MAIN_VITE_`-prefixed vars are exposed to the Electron main process.
#
# Same-machine dev server:      https://localhost:4000  (the default, omit this)
# LAN `npm run dev:host` server: point at that device's IP, e.g.
MAIN_VITE_DEV_URL=https://192.168.68.55:4000

# A one-off override without editing this file:
#   TASFER_DEV_URL=https://192.168.68.55:4000 npm run dev
