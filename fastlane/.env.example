# Copy to fastlane/.env (gitignored) and fill in. See CONTRIBUTING.md "Releases".

# iOS: App Store Connect API key. App Store Connect -> Users and Access ->
# Integrations -> App Store Connect API -> generate an "App Manager" key,
# download the .p8 ONCE and store it OUTSIDE the repo.
# ASC_KEY_ID=XXXXXXXXXX
# ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ASC_KEY_PATH=/Users/you/.private_keys/AuthKey_XXXXXXXXXX.p8

# iOS: App Review contact. Required by the release lane. In CI, configure these
# as repository/environment secrets instead of committing personal details.
# APP_REVIEW_FIRST_NAME=Firstname
# APP_REVIEW_LAST_NAME=Lastname
# APP_REVIEW_PHONE_NUMBER=+46...
# APP_REVIEW_EMAIL_ADDRESS=you@example.com

# Android: Play Developer API service-account JSON key. Create it in Google
# Cloud Console, then invite its email under Play Console -> Users and
# permissions. Store the JSON OUTSIDE the repo.
# PLAY_JSON_KEY_PATH=/Users/you/.private_keys/tasfer-play.json

# Production lanes prompt for confirmation; non-interactive runs must opt in.
# RELEASE_CONFIRM=yes
