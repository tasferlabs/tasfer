# Tasfer store-release automation (iOS App Store + Google Play).
#
# Normally run in CI via the Store Release workflow (public logs); the same
# lanes work locally from the repo root:
#   bundle exec fastlane ios beta         TestFlight
#   bundle exec fastlane ios release      App Store, submits for review
#   bundle exec fastlane android beta     Play open-testing track
#   bundle exec fastlane android release  Play production, submits for review
#
# The web bundle is built + synced into the native projects AUTOMATICALLY during
# the native build (see apps/web/scripts/build-and-sync.sh):
#   - iOS:     an Xcode run-script build phase fires during gym's archive
#   - Android: the Gradle preBuild web-build task fires during `bundle`
# so these lanes only drive the native build + upload.
#
# Versions follow the desktop release: stamp the released v<version> first with
#   npm --prefix apps/web run set:native-version
#
# Secrets are read from fastlane/.env (gitignored) — see fastlane/.env.example.
require "dotenv"
require "fileutils"
Dotenv.load(File.expand_path(".env", __dir__))

default_platform(:ios)

APP_PROJECT = "apps/ios/App/App.xcodeproj"
APP_SCHEME  = "App"
AAB_PATH    = "apps/android/app/build/outputs/bundle/release/app-release.aab"

# ── Release notes (localized) ───────────────────────────────────────────────
# Per-language notes are the source of truth, edited before each release:
#   fastlane/release_notes/<lang>.txt   (en, ar)
# The store-native copies (iOS metadata files, Android per-versionCode
# changelogs) are generated from these at upload time and are gitignored — you
# never hand-edit them.
#
# The App Store and Play use DIFFERENT locale codes for the same language, so
# each app language maps to both:  app lang => [App Store Connect, Play Console].
# `en` is the default/fallback. ALL languages are REQUIRED — a missing or empty
# note file for any supported language blocks the release (never upload empty
# notes, and never let a language silently fall back to English).
RELEASE_NOTES_DIR = File.expand_path("release_notes", __dir__)
IOS_METADATA_DIR = File.expand_path("metadata", __dir__)
IOS_METADATA_UPLOAD_DIR = File.expand_path("../build/ios/metadata", __dir__)
IOS_SCREENSHOTS_DIR = File.expand_path("screenshots", __dir__)
DEFAULT_LANG = "en"

# Play caps changelogs at 500 chars/locale; TestFlight + App Store allow 4000.
PLAY_CHANGELOG_MAX = 500

NOTE_LOCALES = {
  "en" => { asc: "en-US", play: "en-US" },
  "ar" => { asc: "ar-SA", play: "ar"    },
}

# Arabic source files stay checked in for future use, but iOS currently sends
# English only. Android continues to use every language in NOTE_LOCALES.
IOS_LANGS = %w[en].freeze

IOS_LOCALIZED_METADATA_FILES = %w[
  name.txt
  subtitle.txt
  description.txt
  keywords.txt
  promotional_text.txt
  support_url.txt
  marketing_url.txt
  privacy_url.txt
].freeze

IOS_GLOBAL_METADATA_FILES = %w[
  copyright.txt
  primary_category.txt
  review_information/notes.txt
].freeze

IOS_METADATA_LIMITS = {
  "name.txt" => [:length, 30],
  "subtitle.txt" => [:length, 30],
  "description.txt" => [:length, 4_000],
  "keywords.txt" => [:bytesize, 100],
  "promotional_text.txt" => [:length, 170],
}.freeze

# Fail before an expensive archive if the checked-in App Store listing is
# incomplete. Release notes are validated separately because they are generated
# from fastlane/release_notes/<lang>.txt immediately before upload.
def validate_ios_metadata!
  files = IOS_GLOBAL_METADATA_FILES.map { |name| File.join(IOS_METADATA_DIR, name) }
  IOS_LANGS.each do |lang|
    locales = NOTE_LOCALES.fetch(lang)
    IOS_LOCALIZED_METADATA_FILES.each do |name|
      files << File.join(IOS_METADATA_DIR, locales[:asc], name)
    end
  end

  missing = files.select { |path| !File.exist?(path) || File.read(path, encoding: "UTF-8").strip.empty? }
  unless missing.empty?
    relative = missing.map { |path| path.delete_prefix("#{File.expand_path('..', __dir__)}/") }
    UI.user_error!("Missing or empty iOS App Store metadata:\n- #{relative.join("\n- ")}")
  end

  oversized = files.filter_map do |path|
    measure, limit = IOS_METADATA_LIMITS[File.basename(path)]
    next unless measure
    size = File.read(path, encoding: "UTF-8").strip.public_send(measure)
    "#{path.delete_prefix("#{File.expand_path('..', __dir__)}/")} is #{size}; limit is #{limit}" if size > limit
  end
  UI.user_error!("iOS App Store metadata exceeds Apple limits:\n- #{oversized.join("\n- ")}") unless oversized.empty?
end

# Apple currently accepts 1290x2796 portrait captures for the 6.9-inch iPhone
# slot. Keep one to ten opaque PNGs in each enabled App Store locale.
def validate_ios_screenshots!
  expected_size = [1_290, 2_796]

  IOS_LANGS.each do |lang|
    locale = NOTE_LOCALES.fetch(lang)[:asc]
    files = Dir[File.join(IOS_SCREENSHOTS_DIR, locale, "*.png")].sort
    unless (1..10).cover?(files.length)
      UI.user_error!("Expected 1-10 iOS screenshots for #{locale}; found #{files.length}")
    end

    files.each do |path|
      header = File.binread(path, 26)
      unless header.start_with?("\x89PNG\r\n\x1A\n".b) && header.bytesize >= 26
        UI.user_error!("iOS screenshot is not a valid PNG: #{path}")
      end

      width, height = header.byteslice(16, 8).unpack("NN")
      color_type = header.getbyte(25)
      unless [width, height] == expected_size
        UI.user_error!("iOS screenshot must be #{expected_size.join('x')}: #{path} is #{width}x#{height}")
      end
      if [4, 6].include?(color_type)
        UI.user_error!("iOS screenshot must not contain an alpha channel: #{path}")
      end
    end
  end
end

def app_review_information
  required = %w[
    APP_REVIEW_FIRST_NAME
    APP_REVIEW_LAST_NAME
    APP_REVIEW_PHONE_NUMBER
    APP_REVIEW_EMAIL_ADDRESS
  ]
  missing = required.select { |name| ENV[name].to_s.strip.empty? }
  unless missing.empty?
    UI.user_error!("Missing App Review contact environment variables: #{missing.join(', ')}")
  end

  {
    first_name: ENV.fetch("APP_REVIEW_FIRST_NAME"),
    last_name: ENV.fetch("APP_REVIEW_LAST_NAME"),
    phone_number: ENV.fetch("APP_REVIEW_PHONE_NUMBER"),
    email_address: ENV.fetch("APP_REVIEW_EMAIL_ADDRESS"),
    notes: File.read(File.join(IOS_METADATA_DIR, "review_information", "notes.txt"), encoding: "UTF-8").strip,
  }
end

# Read the per-language note for EVERY supported language, keyed by app language.
# Enforces: every language in NOTE_LOCALES is present and non-empty — a missing
# or blank file for any language blocks the release.
def release_notes_by_lang
  notes = {}
  NOTE_LOCALES.each_key do |lang|
    path = File.join(RELEASE_NOTES_DIR, "#{lang}.txt")
    unless File.exist?(path)
      UI.user_error!("Missing fastlane/release_notes/#{lang}.txt — release notes are required for every language (#{NOTE_LOCALES.keys.join(", ")}).")
    end
    text = File.read(path).strip
    UI.user_error!("fastlane/release_notes/#{lang}.txt is empty — every language requires release notes.") if text.empty?
    notes[lang] = text
  end
  notes
end

# TestFlight "What to Test", localized. `default` covers any locale without its
# own entry, so TestFlight never rejects an unconfigured language.
def testflight_localized_info(notes)
  info = { "default" => { whats_new: notes[DEFAULT_LANG] } }
  IOS_LANGS.each { |lang| info[NOTE_LOCALES.fetch(lang)[:asc]] = { whats_new: notes.fetch(lang) } }
  info
end

# Build a generated deliver directory containing only enabled iOS locales.
# Source metadata for disabled locales remains untouched and version-controlled.
def stage_ios_metadata(notes)
  FileUtils.rm_rf(IOS_METADATA_UPLOAD_DIR)
  FileUtils.mkdir_p(IOS_METADATA_UPLOAD_DIR)

  IOS_GLOBAL_METADATA_FILES.each do |name|
    next if name.start_with?("review_information/")
    FileUtils.cp(File.join(IOS_METADATA_DIR, name), File.join(IOS_METADATA_UPLOAD_DIR, name))
  end

  IOS_LANGS.each do |lang|
    locale = NOTE_LOCALES.fetch(lang)[:asc]
    destination = File.join(IOS_METADATA_UPLOAD_DIR, locale)
    FileUtils.cp_r(File.join(IOS_METADATA_DIR, locale), destination)
    File.write(File.join(destination, "release_notes.txt"), notes.fetch(lang))
  end

  IOS_METADATA_UPLOAD_DIR
end

# Play changelogs are keyed by <play-locale>/changelogs/<versionCode>.txt, so
# write them on the fly from the same source. Returns the versionCode.
def stage_android_changelog(notes)
  version_code = android_version_code
  notes.each do |lang, text|
    if text.length > PLAY_CHANGELOG_MAX
      UI.user_error!("fastlane/release_notes/#{lang}.txt is #{text.length} chars; Play allows #{PLAY_CHANGELOG_MAX}.")
    end
    dir = File.expand_path("metadata/android/#{NOTE_LOCALES[lang][:play]}/changelogs", __dir__)
    FileUtils.mkdir_p(dir)
    File.write(File.join(dir, "#{version_code}.txt"), text)
  end
  version_code
end

# Gradle needs a JDK, but macOS ships no system Java, so `gradle` can die with
# "Unable to locate a Java Runtime". Resolve a JDK here and export JAVA_HOME
# for the Gradle steps. Precedence:
#   1. JAVA_HOME (respect an explicit override, e.g. from fastlane/.env)
#   2. /usr/libexec/java_home (a real system/Homebrew JDK, if any)
#   3. Android Studio's bundled JBR (always present for Android devs)
def ensure_java_home
  candidates = []
  candidates << ENV["JAVA_HOME"] if ENV["JAVA_HOME"] && !ENV["JAVA_HOME"].empty?
  detected = `/usr/libexec/java_home 2>/dev/null`.strip
  candidates << detected unless detected.empty?
  candidates << "/Applications/Android Studio.app/Contents/jbr/Contents/Home"

  home = candidates.find { |dir| dir && File.executable?(File.join(dir, "bin", "java")) }
  UI.user_error!(
    "No Java runtime found. Install a JDK (e.g. `brew install --cask temurin`) " \
    "or Android Studio, or set JAVA_HOME in fastlane/.env.",
  ) unless home

  ENV["JAVA_HOME"] = home
  ENV["PATH"] = "#{File.join(home, "bin")}:#{ENV["PATH"]}"
  UI.message("Using JAVA_HOME=#{home}")
  home
end

# Production releases submit straight to store review, so gate them behind an
# explicit confirmation before anything is built or uploaded. Non-interactive
# runs (e.g. CI) must opt in with RELEASE_CONFIRM=yes.
def confirm_release!(prompt)
  return if ENV["RELEASE_CONFIRM"] == "yes"
  unless UI.interactive?
    UI.user_error!("Confirmation required: run interactively or set RELEASE_CONFIRM=yes. (#{prompt})")
  end
  UI.user_error!("Release cancelled — nothing was built or uploaded.") unless UI.confirm(prompt)
end

def ios_marketing_version
  # Explicit encoding: with no LANG set (CI runners) Ruby reads as US-ASCII and
  # any non-ASCII byte in the file makes the regex below raise.
  pbxproj = File.read(File.expand_path("../#{APP_PROJECT}/project.pbxproj", __dir__), encoding: "UTF-8")
  pbxproj[/MARKETING_VERSION = ([^;]+);/, 1]&.strip
end

def android_version_name
  gradle = File.read(File.expand_path("../apps/android/app/build.gradle", __dir__), encoding: "UTF-8")
  gradle[/tasferVersionName\s*=\s*"([^"]+)"/, 1]
end

# build.gradle derives versionCode from versionName rather than storing a literal,
# so mirror that packing here. Keep in step with the block at the top of
# apps/android/app/build.gradle.
def android_version_code
  name = android_version_name
  UI.user_error!("Could not read versionName from apps/android/app/build.gradle") unless name
  parts = name.split(".")
  unless parts.length == 3 && parts.all? { |p| p.match?(/\A\d+\z/) }
    UI.user_error!("versionName '#{name}' is not a bare major.minor.patch semver")
  end
  major, minor, patch = parts.map(&:to_i)
  if minor > 99 || patch > 99
    UI.user_error!("versionName '#{name}': minor and patch must each be <= 99")
  end
  major * 10000 + minor * 100 + patch
end

# App Store Connect API key — non-interactive auth (no Apple ID password / 2FA).
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_PATH"),
    in_house: false,
  )
end

def archive_ios
  xcargs = "-allowProvisioningUpdates"
  # On CI there is no signed-in Xcode account or local certificate, so use
  # Xcode cloud-managed signing: authenticate xcodebuild with the ASC API key
  # and let it fetch/create the distribution cert + profile. setup_ci gives the
  # build a temporary unlocked keychain. No .p12 export, no match repo.
  if ENV["CI"]
    setup_ci
    xcargs += " -authenticationKeyPath #{File.absolute_path(ENV.fetch('ASC_KEY_PATH'))}" \
              " -authenticationKeyID #{ENV.fetch('ASC_KEY_ID')}" \
              " -authenticationKeyIssuerID #{ENV.fetch('ASC_ISSUER_ID')}"
  end
  build_app(
    project: APP_PROJECT,
    scheme: APP_SCHEME,
    export_method: "app-store",
    output_directory: "build/ios",
    clean: true,
    xcargs: xcargs,
  )
end

platform :ios do
  desc "Archive and upload a new build to TestFlight"
  lane :beta do
    api_key = asc_api_key
    notes = release_notes_by_lang
    archive_ios
    upload_to_testflight(
      api_key: api_key,
      localized_build_info: testflight_localized_info(notes), # localized "What to Test"
      skip_waiting_for_build_processing: true,
    )
    UI.success("iOS build uploaded to TestFlight ✈️")
  end

  desc "Archive, upload to the App Store, and submit for review (release manually after approval)"
  lane :release do
    confirm_release!("Submit Tasfer #{ios_marketing_version || "(unknown version)"} to the App Store and send it for review?")
    api_key = asc_api_key
    validate_ios_metadata!
    validate_ios_screenshots!
    notes = release_notes_by_lang
    archive_ios
    metadata_upload_dir = stage_ios_metadata(notes)
    upload_to_app_store(
      api_key: api_key,
      metadata_path: metadata_upload_dir,
      screenshots_path: IOS_SCREENSHOTS_DIR,
      submit_for_review: true,   # send the build to App Store review
      automatic_release: false,  # after approval, press "Release" manually in App Store Connect
      app_review_information: app_review_information,
      # Answers the review questions that would otherwise block/prompt the submission.
      # Adjust if the app ever adds non-exempt encryption or an advertising SDK (IDFA).
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
        content_rights_contains_third_party_content: false,
        content_rights_has_rights: true,
      },
      skip_metadata: false,   # push the checked-in listing and staged "What's New" notes
      skip_screenshots: false, # upload only the checked-in locales (currently en-US)
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      force: true, # skip the HTML preview confirmation prompt
    )
    UI.success("iOS build uploaded to App Store Connect and submitted for review 🍎")
  end
end

platform :android do
  desc "Build a signed AAB and upload to the Play open-testing track"
  lane :beta do
    ensure_java_home
    stage_android_changelog(release_notes_by_lang)
    gradle(project_dir: "apps/android", task: "clean")
    gradle(project_dir: "apps/android", task: "bundle", build_type: "Release")
    upload_to_play_store(
      track: "beta", # Play API name for the Open testing track
      aab: AAB_PATH,
      skip_upload_metadata: true,
      skip_upload_changelogs: false, # upload the staged changelog
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success("Android AAB uploaded to Play open-testing track 🤖")
  end

  desc "Build a signed AAB, upload to the Play production track, and submit for review"
  lane :release do
    confirm_release!("Submit Tasfer #{android_version_name || "(unknown version)"} to Google Play production and send it for review?")
    ensure_java_home
    stage_android_changelog(release_notes_by_lang)
    gradle(project_dir: "apps/android", task: "clean")
    gradle(project_dir: "apps/android", task: "bundle", build_type: "Release")
    upload_to_play_store(
      track: "production",
      aab: AAB_PATH,
      release_status: "completed", # send for review; goes live to 100% on approval
      changes_not_sent_for_review: false,
      skip_upload_metadata: true,
      skip_upload_changelogs: false, # upload the staged changelog
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success("Android AAB uploaded to Play production and submitted for review 🤖")
  end
end
