{
  "name": "@tasfer/provider-relay",
  "version": "0.0.0",
  "description": "WebSocket-relay transport for @tasfer/editor — peers behind NATs sync through a relay that forwards their updates. The relay is a trusted party: frames are not encrypted.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "peerDependencies": {
    "@tasfer/editor": "*",
    "@tasfer/provider-core": "*",
    "typescript": ">=5.9.3"
  },
  "devDependencies": {
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2"
  }
}
