{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    // Resolve sibling @cypherkit packages from their built dist declarations.
    // Build them in dependency order: editor and provider-core before this.
    "paths": {
      "*": ["./*"],
      "@cypherkit/editor": ["../editor/dist/index.d.mts"],
      "@cypherkit/editor/*": ["../editor/dist/*"],
      "@cypherkit/provider-core": ["../provider-core/dist/index.d.mts"],
      "@cypherkit/provider-core/*": ["../provider-core/dist/*"]
    }
  },
  "include": ["src"]
}
