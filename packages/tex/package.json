{
  "name": "@cypherkit/tex",
  "version": "0.0.0",
  "description": "Canvas-native, live-editable LaTeX math layout & rendering engine.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "sideEffects": false,
  "files": ["dist", "NOTICE"],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.mts", "default": "./dist/index.mjs" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./*": {
      "import": { "types": "./dist/*.d.mts", "default": "./dist/*.mjs" },
      "require": { "types": "./dist/*.d.cts", "default": "./dist/*.cjs" }
    }
  },
  "scripts": {
    "build": "tsdown",
    "gen:math-icons": "node scripts/gen-math-chip-icons.mjs",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "spike:metrics": "vitest run src/data/__spike__/metric-match.test.ts",
    "render:check": "vitest run src/paint/render.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@napi-rs/canvas": "1.0.0",
    "@types/node": "^25.9.3",
    "@types/opentype.js": "^1.3.10",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "katex": "^0.16.11",
    "opentype.js": "^1.3.4",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.8"
  }
}
