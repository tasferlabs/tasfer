{
  "name": "@tasfer/tex",
  "version": "0.1.0",
  "private": true,
  "description": "Canvas-native, live-editable LaTeX math layout & rendering engine.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamza512b/tasfer.git",
    "directory": "packages/tex"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "sideEffects": false,
  "files": [
    "dist",
    "NOTICE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./data": {
      "import": {
        "types": "./dist/data.d.mts",
        "default": "./dist/data.mjs"
      },
      "require": {
        "types": "./dist/data.d.cts",
        "default": "./dist/data.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "scripts": {
    "prepublishOnly": "node -e \"throw new Error('Publishing is disabled while the SDK is internal')\"",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "gen:math-icons": "npm run build && node scripts/gen-math-chip-icons.mjs",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "spike:metrics": "vitest run src/data/__spike__/metric-match.test.ts",
    "render:check": "vitest run src/paint/render.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "typescript": ">=5.9.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/plugin-syntax-typescript": "^8.0.3",
    "@napi-rs/canvas": "1.0.0",
    "@types/node": "^25.9.3",
    "@types/opentype.js": "^1.3.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "katex": "^0.18.1",
    "opentype.js": "^1.3.4",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.8"
  }
}
