{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    // Resolve sibling @tasfer packages from their built dist declarations
    // (self-contained). Build them in dependency order: editor before this.
    "paths": {
      "*": ["./*"],

      "@tasfer/editor": ["../editor/dist/index.d.mts"],
      "@tasfer/editor/*": ["../editor/dist/*"]
    }
  },
  "include": ["src"]
}
