{
  "name": "@cypherkit/editor",
  "version": "0.0.0",
  "description": "Canvas-based, CRDT-powered block editor engine (headless core).",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.mts", "default": "./dist/index.mjs" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./*": {
      "import": { "types": "./dist/*.d.mts", "default": "./dist/*.mjs" },
      "require": { "types": "./dist/*.d.cts", "default": "./dist/*.cjs" }
    }
  },
  "peerDependencies": {
    "@cypherkit/tex": "*",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "defuddle": "^0.18.1",
    "lowlight": "^3.3.0"
  }
}
