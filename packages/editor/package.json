{
  "name": "@tasfer/editor",
  "version": "0.1.0",
  "private": true,
  "description": "Canvas-based, CRDT-powered block editor engine (headless core).",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamza512b/tasfer.git",
    "directory": "packages/editor"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepublishOnly": "node -e \"throw new Error('Publishing is disabled while the SDK is internal')\"",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./math": {
      "import": {
        "types": "./dist/math/index.d.mts",
        "default": "./dist/math/index.mjs"
      },
      "require": {
        "types": "./dist/math/index.d.cts",
        "default": "./dist/math/index.cjs"
      }
    },
    "./math/data": {
      "import": {
        "types": "./dist/math/data.d.mts",
        "default": "./dist/math/data.mjs"
      },
      "require": {
        "types": "./dist/math/data.d.cts",
        "default": "./dist/math/data.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "peerDependencies": {
    "@tasfer/tex": "*",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": ">=5.9.3"
  },
  "peerDependenciesMeta": {
    "@tasfer/tex": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@babel/plugin-syntax-typescript": "^8.0.3",
    "@types/react": "^19.2.16",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "defuddle": "^0.19.1",
    "lowlight": "^3.3.0"
  }
}
