{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": false,
    "paths": {
      "@cypherkit/tex": ["../../tex/dist/index.d.mts"],
      "@cypherkit/tex/data": ["../../tex/dist/data.d.mts"]
    }
  },
  "include": ["*.ts"]
}
