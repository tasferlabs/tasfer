{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "react-jsx",
    // Resolve sibling @cypherkit packages from their built dist declarations
    // (react re-exports editor types that reference @cypherkit/tex). Build them
    // in dependency order: tex and editor before this. React's own types come
    // from the locally-installed @types/react(-dom) devDependencies.
    "paths": {
      "*": ["./*"],
      "@cypherkit/editor": ["../editor/dist/index.d.mts"],
      "@cypherkit/editor/*": ["../editor/dist/*"],
      "@cypherkit/tex": ["../tex/dist/index.d.mts"],
      "@cypherkit/tex/*": ["../tex/dist/*"]
    }
  },
  "include": ["src"]
}
