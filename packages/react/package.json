{
  "name": "@tasfer/react",
  "version": "0.1.0",
  "private": true,
  "description": "React 19 bindings for @tasfer/editor — a useEditor hook, an <Editor> component, and live state subscriptions.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tasferlabs/tasfer.git",
    "directory": "packages/react"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "scripts": {
    "prepublishOnly": "node -e \"throw new Error('Publishing is disabled while the SDK is internal')\"",
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "peerDependencies": {
    "@tasfer/editor": "*",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": ">=5.9.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2"
  }
}
