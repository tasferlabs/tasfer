NODE_ENV=production

# Database
DATABASE_URL=postgresql://postgres:postgres@172.18.0.100:5432/cypher                                                              
REDIS_URL=redis://172.18.0.101:6379    

# Traefik basic auth (generate with: htpasswd -nb username password)
# Example: htpasswd -nb admin secret123
TRAEFIK_AUTH=admin:$apr1$xyz...

# Live server auth key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))")
LIVE_AUTH_KEY=your-secret-key-here
